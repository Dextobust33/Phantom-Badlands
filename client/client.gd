				display_game("[color=#FFFF00]%s[/color]" % broadcast_msg)
				display_game("[color=#FF4444]========================================[/color]")
				display_game("")
				# Also show in chat
				display_chat("[color=#FF4444][SERVER] %s[/color]" % broadcast_msg)
