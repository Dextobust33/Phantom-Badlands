		style_hover.border_color = THEME_BORDER_GOLD
		style_hover.set_border_width_all(1)
		style_hover.set_corner_radius_all(3)
		style_hover.set_content_margin_all(3)
		btn.add_theme_stylebox_override("normal", style_normal)
